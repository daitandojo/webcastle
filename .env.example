# Scraping Service Configuration

# Server Configuration
PORT=3002
NODE_ENV=development
LOG_LEVEL=info

# API Authentication
API_KEYS=scraping-key-1,scraping-key-2  # Comma-separated API keys for authentication
REQUIRE_AUTH=true  # Set to false to disable API key authentication

# Scraping Configuration
SCRAPER_TIMEOUT_MS=30000
SCRAPER_CONCURRENT=3
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/120.0.0.0 Safari/537.36
SCRAPER_RATE_LIMIT_RPS=10
SCRAPER_MAX_URLS_PER_BATCH=10
SCRAPER_DEFAULT_FIDELITY=DEEP  # FAST or DEEP
SCRAPER_DEFAULT_MODE=CLEAN_TEXT  # CLEAN_TEXT, FULL_HTML, PRECISION_SELECTORS, IMAGE_HUNT

# Browser Configuration (Playwright)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_STEALTH_MODE=true
PLAYWRIGHT_BROWSER_PATH=  # Leave empty for automatic installation
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_VIEWPORT_WIDTH=1440
PLAYWRIGHT_VIEWPORT_HEIGHT=900

# Caching Configuration
CACHE_ENABLED=true
CACHE_TTL_MS=3600000  # 1 hour in milliseconds
CACHE_MAX_ITEMS=1000

# Rate Limiting (per IP)
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100   # Max requests per IP per window

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Cogniti Integration (for /store endpoint)
COGNITI_API_URL=http://localhost:3000
COGNITI_USER_EMAIL=  # Default user email for store operations

# Temporary Storage
TEMP_DIR=./temp
CLEANUP_INTERVAL_HOURS=24