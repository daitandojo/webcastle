{
  "name": "webcastle",
  "version": "1.0.0",
  "description": "WebCastle - AI-Powered Web Scraping API with YouTube transcripts, LLM extraction, and adaptive crawling",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:all": "npm run dev:kill && npm run dev",
    "dev:kill": "fuser -k 3052/tcp 2>/dev/null || true",
    "clean": "rm -rf dist",
    "install-browsers": "npx playwright install chromium",
    "test": "jest",
    "test:all": "ts-node scripts/test-all.ts"
  },
  "keywords": [
    "webcastle",
    "web-scraping",
    "api",
    "youtube-transcript",
    "llm",
    "crawling",
    "data-extraction",
    "scraping"
  ],
  "author": "WebCastle",
  "license": "MIT",
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "exponential-backoff": "^3.1.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsdom": "25.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "node-fetch": "^2.7.0",
    "p-limit": "^5.0.0",
    "playwright": "^1.57.0",
    "postgres": "^3.4.8",
    "stripe": "^21.0.1",
    "turndown": "^7.2.2",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsdom": "21.1.7",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.33",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.20.0",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.10",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
